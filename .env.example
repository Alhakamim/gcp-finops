# ═══════════════════════════════════════════════════════════
# CntxtLens — GCP FinOps Platform
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and modify values

# JWT Secret (REQUIRED: change this in production!)
JWT_SECRET=your-strong-random-secret-at-least-32-chars

# Port (default: 3001)
PORT=3001

# ═══════════════════════════════════════════════════════════
# GCP Integration (optional)
# ═══════════════════════════════════════════════════════════
# GCP_SERVICE_ACCOUNT_KEY=/path/to/key.json
# GCP_PROJECT_ID=your-gcp-project
# GCP_BILLING_ACCOUNT_ID=XXXXXX-XXXXXX-XXXXXX

# ═══════════════════════════════════════════════════════════
# Getting Started
# ═══════════════════════════════════════════════════════════
# 1. docker compose up -d
# 2. Open http://localhost:3001
# 3. First registered user = admin
# 4. Add team members and API keys
# 5. Connect GCP billing data
